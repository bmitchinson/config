#!/usr/bin/env bash
set -euo pipefail

repo="/Users/bmitchinson/repos/personal/pi-sessions"

if [[ ! -d "$repo/.git" ]]; then
  echo "Not a git repo: $repo" >&2
  exit 1
fi

cd "$repo"

branch="$(git branch --show-current)"
if [[ "$branch" != "main" ]]; then
  echo "Refusing to run: active branch is '$branch', expected 'main'" >&2
  exit 1
fi

git add -A

if git diff --cached --quiet; then
  echo "No changes to commit"
  exit 0
fi

git commit -m "automatic push"
git push
